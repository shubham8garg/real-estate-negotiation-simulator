# ─── Real Estate Negotiation Workshop — Environment Variables ─────────────────
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Then load it before running:
#   source .env          (bash/zsh)
#   # or use python-dotenv: the workshop loads it automatically
#
# NEVER commit your actual .env to git (it's already in .gitignore).
# ──────────────────────────────────────────────────────────────────────────────


# ─── Module 3: Simple Version (OpenAI GPT-4o) ────────────────────────────────
# Required to run: python m3_langgraph_multiagents/main_langgraph_multiagent.py
# Get your key: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-key-here


# ─── Module 4: ADK Version (Gemini 2.0 Flash — FREE) ─────────────────────────
# Required to run: python m4_adk_multiagents/main_adk_multiagent.py
# Get your FREE key: https://aistudio.google.com  (no credit card required)
GOOGLE_API_KEY=AIza-your-google-key-here


# ─── Module 2: GitHub MCP Demo (optional) ────────────────────────────────────
# Required to run: python m2_mcp/github_demo_client.py
# Get a token: GitHub -> Settings -> Developer Settings -> Personal Access Tokens -> Classic
# Minimum scopes: public_repo (or repo for private repos)
GITHUB_TOKEN=ghp_your-github-token-here


# ─── Optional Overrides ───────────────────────────────────────────────────────
# These have sensible defaults — only set if you want to change them.

# Maximum negotiation rounds (default: 5)
# MAX_ROUNDS=5

# Buyer's maximum budget in dollars (default: 460000)
# BUYER_BUDGET=460000

# Seller's minimum acceptable price in dollars (default: 445000)
# SELLER_MINIMUM=445000
